# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Ticketing System"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_generate_with_artisan_key_generate
APP_DEBUG=false
APP_URL=https://sts-demo.betamaxgroup.tech

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ticketing
DB_USERNAME=ticketing
DB_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Session / Cache / Queue — all redis in production ────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ─── Broadcasting ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (optional — only if using S3 for file storage) ──────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Proxy / HTTPS ────────────────────────────────────────────────────────────
# Caddy runs on the host and proxies to nginx on 127.0.0.1:8080.
# List the host IP(s) that Caddy forwards from so Laravel trusts X-Forwarded-* headers.
TRUSTED_PROXIES=127.0.0.1,::1

# ─── Startup behaviour ────────────────────────────────────────────────────────
# Set to true on first deploy to seed the database; false thereafter
SEED_ON_STARTUP=true
