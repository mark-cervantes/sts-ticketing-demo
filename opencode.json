{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "postgres": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@henkey/postgres-mcp-server",
                "--connection-string",
                "postgresql://sail:password@localhost:5432/laravel"
            ],
            "enabled": true
        },
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    }
}